        </range>
      </lidar>
      <ros>
        <frame_name>base_scan</frame_name>
      </ros>
    </sensor>
  </gazebo> -->

<gazebo reference="left_camera_frame">
    <sensor name="left_camera" type="camera">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <topic>left_camera/image_raw</topic>
        <gz_frame_id>left_camera_optical_frame</gz_frame_id>
        <frame_id>left_camera_optical_frame</frame_id>
        <camera>
            <horizontal_fov>1.0472</horizontal_fov>
            <image>
                <width>2304</width>
                <height>1296</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <near>0.01</near>
                <far>100</far>
            </clip>
        </camera>
    </sensor>
</gazebo>

<gazebo reference="right_camera_frame">
    <sensor name="right_camera" type="camera">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <topic>right_camera/image_raw</topic>
        <gz_frame_id>right_camera_optical_frame</gz_frame_id>
        <frame_id>right_camera_optical_frame</frame_id>
        <camera>
            <horizontal_fov>1.0472</horizontal_fov>
            <anti_aliasing>0</anti_aliasing>
            <image>
                <width>2304</width> 
                <height>1296</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <near>0.01</near>
                <far>100</far>
            </clip>
        </camera>
    </sensor>
</gazebo>



</robot>
