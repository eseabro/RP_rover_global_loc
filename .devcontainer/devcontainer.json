{
    "name": "RP Rover Global Localization Dev Container",
    "privileged": true,
    "remoteUser": "Emma",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "Emma"
        }
    },
    "workspaceFolder": "/home/ws",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/ws,type=bind",
    "customizations": {
        "vscode": {
            "extensions":[
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-themes",
                "twxs.cmake",
                "donjayamanne.python-extension-pack",
                "eamodio.gitlens",
                "ms-iot.vscode-ros"
            ]
        }
    },
    "runArgs": [
        "--network=host",
        "--device=/dev/dxg",
        "--volume=/tmp/.X11-unix:/tmp/.X11-unix:rw",
        "--volume=/mnt/wslg:/mnt/wslg:ro"
    ],
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY:-:0}",
        "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
        "XDG_RUNTIME_DIR": "/mnt/wslg/runtime-dir",
        "PULSE_SERVER": "/mnt/wslg/PulseServer",
        "QT_X11_NO_MITSHM": "1",
        "ROS_AUTOMATIC_DISCOVERY_RANGE": "LOCALHOST"
    },
    "postCreateCommand": "sudo rosdep update && sudo rosdep install --from-paths src --ignore-src -y && sudo chown -R $(whoami) /home/ws/ && echo 'export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/opt/ros/jazzy/lib' >> ~/.bashrc"
}